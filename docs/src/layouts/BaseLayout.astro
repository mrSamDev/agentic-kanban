---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const canonicalUrl = canonical || `https://mrsamdev.github.io${Astro.url.pathname}`;
---

<!DOCTYPE html>
<html lang="en" data-theme="">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <meta name="theme-color" content="#f4f5f0">
  <link rel="icon" type="image/svg+xml" href="/agentic-kanban/favicon.svg">
  <title>{title}</title>
  <link rel="canonical" href={canonicalUrl}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&amp;family=Geist+Mono:wght@400;500;600&amp;display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/agentic-kanban/style.css">
  <script is:inline>(function(){var t=localStorage.getItem("theme")||(window.matchMedia("(prefers-color-scheme:dark)").matches?"dark":"");if(t)document.documentElement.setAttribute("data-theme",t)})()</script>
</head>
<body>
  <header class="site-header">
    <nav class="nav-shell" aria-label="Primary navigation">
      <a class="brand" href="/agentic-kanban/">agentic-kanban</a>
      <div class="nav-links">
        <a href="/agentic-kanban/install/">Install</a>
        <a href="/agentic-kanban/commands/">Commands</a>
        <a href="/agentic-kanban/examples/">Examples</a>
      </div>
      <div class="nav-actions">
        <button class="theme-toggle" id="themeToggle" type="button" aria-label="Switch to dark mode" title="Switch theme">
          <svg class="moon-icon" aria-hidden="true" viewBox="0 0 24 24"><path d="M20 15.2A8.5 8.5 0 0 1 8.8 4a8.5 8.5 0 1 0 11.2 11.2Z"/></svg>
          <svg class="sun-icon" aria-hidden="true" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3.5"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
        </button>
        <a href="https://github.com/mrSamDev/agentic-kanban" class="github-link">
          <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M12 2a10 10 0 0 0-3.2 19.5c.5.1.7-.2.7-.5v-1.9c-2.8.6-3.4-1.2-3.4-1.2-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 0 1.6 1.1 1.6 1.1.9 1.6 2.4 1.1 3 .9.1-.7.4-1.1.7-1.3-2.3-.3-4.7-1.1-4.7-5A3.9 3.9 0 0 1 6.7 8.8c-.1-.3-.5-1.3.1-2.7 0 0 .9-.3 2.8 1a9.7 9.7 0 0 1 5.1 0c2-1.3 2.8-1 2.8-1 .6 1.4.2 2.4.1 2.7a3.9 3.9 0 0 1 1 2.7c0 3.9-2.4 4.7-4.7 5 .4.3.7 1 .7 2V21c0 .3.2.6.7.5A10 10 0 0 0 12 2Z"/></svg>
          <span>GitHub</span>
        </a>
      </div>
    </nav>
  </header>

  <slot />

  <footer>
    <div class="footer-inner">
      <div class="footer-brand">
        <a class="brand" href="/agentic-kanban/">agentic-kanban</a>
        <p>SQLite-backed task coordination for AI agents.</p>
        <p>MIT License · <a href="https://github.com/mrSamDev">mrSamDev</a></p>
      </div>
      <nav class="footer-nav" aria-label="Documentation">
        <a href="/agentic-kanban/install/">Install</a>
        <a href="/agentic-kanban/commands/">Commands</a>
        <a href="/agentic-kanban/protocol/">Protocol</a>
        <a href="/agentic-kanban/skills/">Skills</a>
        <a href="/agentic-kanban/hooks/">Hooks</a>
        <a href="/agentic-kanban/architecture/">Architecture</a>
        <a href="/agentic-kanban/examples/">Examples</a>
      </nav>
    </div>
  </footer>

  <script>
    (function () {
      var html = document.documentElement;
      var themeToggle = document.getElementById("themeToggle");
      var themeColor = document.querySelector('meta[name="theme-color"]');
      var savedTheme = localStorage.getItem("theme");
      var systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;

      function setTheme(theme) {
        html.setAttribute("data-theme", theme);
        if (themeToggle) themeToggle.setAttribute("aria-label", "Switch to " + (theme === "dark" ? "light" : "dark") + " mode");
        if (themeColor) themeColor.setAttribute("content", theme === "dark" ? "#121511" : "#f4f5f0");
      }

      setTheme(savedTheme || (systemDark ? "dark" : "light"));

      if (themeToggle) {
        themeToggle.addEventListener("click", function () {
          var nextTheme = html.getAttribute("data-theme") === "dark" ? "light" : "dark";
          setTheme(nextTheme);
          localStorage.setItem("theme", nextTheme);
          themeToggle.blur();
        });
      }
    })();
  </script>
</body>
</html>
